<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml" minWidth="800">
    <top>
    <VBox>
        <MenuBar fx:id="menuBar" useSystemMenuBar="true">
            <menus>
                <Menu text="Autogram">
                    <items>
                        <MenuItem text="O Autograme" onAction="#onAboutButtonAction" accelerator="shortcut+I"/>
                        <MenuItem text="Nastavenia" onAction="#onSettingButtonAction" accelerator="shortcut+COMMA"/>
                        <SeparatorMenuItem/>
                        <MenuItem text="Skontrolovať aktualizácie" onAction="#onCheckUpdateButtonAction"/>
                        <SeparatorMenuItem/>
                        <MenuItem text="Ukončiť" onAction="#onQuitButtonAction" accelerator="shortcut+Q"/>
                    </items>
                </Menu>
                <Menu text="Súbor">
                    <items>
                        <MenuItem text="Otvoriť súbor..." onAction="#onUploadButtonAction" accelerator="shortcut+O"/>
                    </items>
                </Menu>
                <Menu text="Upraviť">
                    <items>
                        <MenuItem text="Späť" accelerator="shortcut+Z"/>
                        <MenuItem text="Zopakovať" accelerator="shift+shortcut+Z"/>
                        <SeparatorMenuItem/>
                        <MenuItem text="Vystrihnúť" accelerator="shortcut+X"/>
                        <MenuItem text="Kopírovať" accelerator="shortcut+C"/>
                        <MenuItem text="Vložiť" accelerator="shortcut+V"/>
                        <MenuItem text="Vybrať všetko" accelerator="shortcut+A"/>
                    </items>
                </Menu>
                <Menu text="Okno">
                    <items>
                        <MenuItem text="Minimalizovať" accelerator="shortcut+M"/>
                        <MenuItem text="Zavrieť okno" accelerator="shortcut+W"/>
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </VBox>
    </top>
    <center>
        <SplitPane fx:id="splitPane" dividerPositions="0.28" styleClass="autogram-split-pane">
            <!-- Left sidebar -->
            <VBox fx:id="sidebar" styleClass="autogram-sidebar" minWidth="200" maxWidth="260">
                <VBox styleClass="autogram-sidebar-header">
                    <Label styleClass="autogram-claim,autogram-heading-l">Autogram</Label>
                    <TextFlow><Text styleClass="autogram-body" text="Nástroj na&#160;podpisovanie"/></TextFlow>
                </VBox>

                <VBox styleClass="autogram-sidebar-nav" VBox.vgrow="ALWAYS" spacing="4">
                    <Button styleClass="autogram-sidebar-item,autogram-sidebar-item--active" fx:id="navDropZone" onAction="#onNavDropZone">
                        <graphic>
                            <SVGPath styleClass="autogram-sidebar-icon" content="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m3.75 9v6m3-3H9m1.5-12H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
                        </graphic>
                        Vybrať súbor
                    </Button>
                    <Button styleClass="autogram-sidebar-item" fx:id="navSettings" onAction="#onSettingButtonAction">
                        <graphic>
                            <SVGPath styleClass="autogram-sidebar-icon" content="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z"/>
                        </graphic>
                        Nastavenia
                    </Button>
                    <Button styleClass="autogram-sidebar-item" fx:id="navAbout" onAction="#onAboutButtonAction">
                        <graphic>
                            <SVGPath styleClass="autogram-sidebar-icon" content="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/>
                        </graphic>
                        O Autograme
                    </Button>
                </VBox>

                <!-- Document Information Sidebar Section -->
                <VBox fx:id="metadataPanel" styleClass="autogram-sidebar-metadata" visible="false" managed="false" spacing="12">
                    <VBox styleClass="autogram-sidebar-card" spacing="12">
                        <Label styleClass="autogram-sidebar-section-title">Informácie o dokumente</Label>
                        <Label styleClass="autogram-body-s" wrapText="true"
                               text="Prehľad práve otvoreného dokumentu a aktívneho certifikátu."/>
                        <VBox spacing="10">
                            <VBox styleClass="autogram-metadata-row" spacing="2">
                                <Label styleClass="autogram-metadata-label" text="Súbor"/>
                                <Label fx:id="metaFilename" styleClass="autogram-metadata-value,autogram-metadata-value--strong" wrapText="true"/>
                            </VBox>
                            <VBox styleClass="autogram-metadata-row" spacing="2">
                                <Label styleClass="autogram-metadata-label" text="Veľkosť"/>
                                <Label fx:id="metaSize" styleClass="autogram-metadata-value"/>
                            </VBox>
                            <VBox styleClass="autogram-metadata-row" spacing="2">
                                <Label styleClass="autogram-metadata-label" text="Strany"/>
                                <Label fx:id="metaPages" styleClass="autogram-metadata-value"/>
                            </VBox>
                            <VBox styleClass="autogram-metadata-row" spacing="2">
                                <Label styleClass="autogram-metadata-label" text="Formát"/>
                                <Label fx:id="metaFormat" styleClass="autogram-metadata-value"/>
                            </VBox>
                            <VBox styleClass="autogram-metadata-row" spacing="2">
                                <Label styleClass="autogram-metadata-label" text="Certifikát"/>
                                <Label fx:id="metaCertificate" styleClass="autogram-metadata-value" wrapText="true"/>
                            </VBox>
                        </VBox>
                    </VBox>

                    <Separator fx:id="existingSignaturesSeparator" styleClass="autogram-separator" visible="false" managed="false"/>

                    <VBox styleClass="autogram-sidebar-card" visible="false" managed="false" fx:id="existingSignaturesCard">
                        <TitledPane fx:id="existingSignaturesPane" text="Existujúce podpisy" expanded="false" visible="false" managed="false" animated="true">
                            <VBox fx:id="existingSignaturesList" spacing="6" />
                        </TitledPane>
                    </VBox>
                </VBox>

                <VBox styleClass="autogram-sidebar-footer">
                    <Label fx:id="statusLabel" styleClass="autogram-sidebar-status">Pripravený</Label>
                </VBox>
            </VBox>

            <!-- Right content area -->
            <StackPane fx:id="contentArea" styleClass="autogram-content-area" minWidth="600">
                <!-- Content Panel Container (Blurred Background) -->
                <StackPane fx:id="contentPanelContainer">
                    <!-- Drop zone (default view) -->
                    <VBox fx:id="dropZonePanel" styleClass="autogram-content-panel,autogram-welcome-panel" alignment="TOP_CENTER">
                        <VBox spacing="28" alignment="TOP_CENTER" maxWidth="900" VBox.vgrow="ALWAYS">
                            <VBox styleClass="autogram-hero-card" spacing="24">
                                <VBox styleClass="autogram-hero-copy" spacing="12">
                                    <Label styleClass="autogram-eyebrow" text="Podpisovanie a overovanie dokumentov" />
                                    <TextFlow textAlignment="LEFT"><Text styleClass="autogram-hero-title" text="Vyberte dokument a skontrolujte ho pred podpisom" /></TextFlow>
                                    <TextFlow>
                                        <Text styleClass="autogram-body-l" text="Autogram vás prevedie otvorením súboru, kontrolou existujúcich podpisov a samotným podpisom v jednom okne. Otvoriť môžete jeden dokument aj viac súborov naraz pre hromadné podpisovanie." />
                                    </TextFlow>
                                </VBox>

                                <FlowPane styleClass="autogram-hero-steps" hgap="12" vgap="12">
                                    <VBox styleClass="autogram-hero-step" prefWidth="250" spacing="6">
                                        <Label styleClass="autogram-hero-step__index" text="1" />
                                        <Label styleClass="autogram-hero-step__title" text="Vyberte dokument" />
                                        <Label styleClass="autogram-hero-step__body" wrapText="true"
                                               text="Otvorte PDF, XML alebo iný podporovaný súbor z disku alebo ho presuňte myšou." />
                                    </VBox>
                                    <VBox styleClass="autogram-hero-step" prefWidth="250" spacing="6">
                                        <Label styleClass="autogram-hero-step__index" text="2" />
                                        <Label styleClass="autogram-hero-step__title" text="Skontrolujte obsah" />
                                        <Label styleClass="autogram-hero-step__body" wrapText="true"
                                               text="Pozrite si náhľad dokumentu, existujúce podpisy a upozornenia pred finálnym podpisom." />
                                    </VBox>
                                    <VBox styleClass="autogram-hero-step" prefWidth="250" spacing="6">
                                        <Label styleClass="autogram-hero-step__index" text="3" />
                                        <Label styleClass="autogram-hero-step__title" text="Podpíšte s istotou" />
                                        <Label styleClass="autogram-hero-step__body" wrapText="true"
                                               text="Zvoľte certifikát, formát podpisu a časovú pečiatku bez prepínania medzi oknami." />
                                    </VBox>
                                </FlowPane>

                                <VBox fx:id="dropZone" alignment="CENTER" spacing="20.0" styleClass="autogram-dropzone,autogram-dropzone--hero" VBox.vgrow="ALWAYS" minHeight="190" accessibleRole="BUTTON" accessibleText="Oblasť pre výber súborov. Stlačte Enter alebo medzerník pre výber súborov, alebo sem presuňte súbory myšou.">
                                    <SVGPath styleClass="autogram-icon,autogram-icon--big" content="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m3.75 9v6m3-3H9m1.5-12H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" accessibleText="Ikona nahrávania súborov"/>
                                    <TextFlow textAlignment="CENTER">
                                        <Button styleClass="autogram-button,autogram-button--secondary" fx:id="uploadButton" onAction="#onUploadButtonAction" accessibleText="Tlačidlo pre výber súborov na podpísanie">Vyberte súbor</Button>
                                        <Text styleClass="autogram-body" text=" alebo ho presuňte sem" />
                                    </TextFlow>
                                    <Label styleClass="autogram-dropzone-hint"
                                           wrapText="true"
                                           text="Klávesnica: Enter alebo medzerník. Menu: Súbor → Otvoriť súbor…" />
                                </VBox>

                                <VBox spacing="10">
                                    <Label styleClass="autogram-sidebar-section-title" text="Najčastejšie formáty" />
                                    <FlowPane styleClass="autogram-pill-row" hgap="8" vgap="8">
                                        <Label styleClass="autogram-pill,autogram-pill--neutral" text="PDF" />
                                        <Label styleClass="autogram-pill,autogram-pill--neutral" text="XAdES XML" />
                                        <Label styleClass="autogram-pill,autogram-pill--neutral" text="CAdES" />
                                        <Label styleClass="autogram-pill,autogram-pill--neutral" text="eForm" />
                                        <Label styleClass="autogram-pill,autogram-pill--neutral" text="Hromadné podpisovanie" />
                                    </FlowPane>
                                </VBox>
                            </VBox>
                        </VBox>
                    </VBox>

                    <!-- Signing preview panel (hidden by default, shown when signing) -->
                    <VBox fx:id="signingPanel" styleClass="autogram-content-panel" visible="false" managed="false" minWidth="600">
                    </VBox>

                    <!-- Success panel (hidden by default) -->
                    <VBox fx:id="successPanel" styleClass="autogram-content-panel" visible="false" managed="false">
                    </VBox>

                    <!-- Settings panel (hidden by default) -->
                    <VBox fx:id="settingsPanel" styleClass="autogram-content-panel" visible="false" managed="false" minWidth="600">
                    </VBox>
                </StackPane>

                <!-- Modal Overlay for Dialogs -->
                <StackPane fx:id="dialogOverlay" visible="false" managed="false" styleClass="autogram-overlay-backdrop">
                    <VBox fx:id="dialogContainer" alignment="CENTER" spacing="0"
                          styleClass="autogram-overlay-card">
                        <VBox fx:id="dialogContentHost" alignment="CENTER" styleClass="autogram-dialog-host" />
                    </VBox>
                </StackPane>
            </StackPane>

            <!-- Right Sidebar Drawer (Signature Details) -->
            <VBox fx:id="rightDrawer" styleClass="autogram-right-drawer" minWidth="0" maxWidth="800" visible="false" managed="false">
                <HBox styleClass="autogram-right-drawer-header" alignment="CENTER_LEFT" spacing="10">
                    <Button onAction="#onHideRightDrawer" styleClass="autogram-button-icon">
                        <graphic>
                            <SVGPath content="M6 18L18 6M6 6l12 12" styleClass="autogram-icon" />
                        </graphic>
                    </Button>
                    <Label styleClass="autogram-heading-s">Detaily podpisov</Label>
                </HBox>
                <StackPane fx:id="rightDrawerContent" VBox.vgrow="ALWAYS" styleClass="autogram-right-drawer-content">
                    <!-- Dynamic content injected here -->
                </StackPane>
            </VBox>
        </SplitPane>
    </center>
</BorderPane>
