<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.TextFlow?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:id="mainBox"
      spacing="12"
      styleClass="autogram-dialog-content,autogram-dialog-content--compact,autogram-prose">
    <TextFlow>
        <Text styleClass="autogram-heading-m" text="Chcete zresetovať nastavenia?" />
    </TextFlow>

    <TextFlow>
        <Text styleClass="autogram-body"
              text="Táto akcia zresetuje všetky nastavenia na ich pôvodné predvolené hodnoty." />
    </TextFlow>

    <HBox styleClass="autogram-actions" alignment="CENTER_RIGHT">
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="rejectResetButton" onAction="#onRejectResetButtonAction"
                styleClass="autogram-button,autogram-button--secondary" text="Zrušiť" />
        <Button fx:id="confirmResetButton" onAction="#onConfirmResetButtonAction"
                styleClass="autogram-button,autogram-button--primary" text="Resetovať nastavenia" />
    </HBox>
</VBox>
