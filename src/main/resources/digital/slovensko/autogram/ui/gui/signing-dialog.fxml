<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.text.*?>
<?import javafx.scene.web.WebView?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:id="mainBox" styleClass="autogram-signing-shell">

    <VBox styleClass="autogram-signing-head,autogram-signing-head-card" spacing="10">
        <Label fx:id="signingStateLabel" styleClass="autogram-eyebrow" text="Kontrola dokumentu" />
        <TextFlow>
            <Text fx:id="headerText" styleClass="autogram-hero-title" />
        </TextFlow>
        <Label fx:id="headerHelpLabel"
               styleClass="autogram-signing-help"
               wrapText="true"
               text="Skontrolujte náhľad dokumentu, existujúce podpisy a zvolený certifikát pred podpisom." />
        <FlowPane fx:id="signingBadgeRow" styleClass="autogram-pill-row,autogram-signing-badges" hgap="8" vgap="8">
            <Label fx:id="documentTypeBadge" styleClass="autogram-pill,autogram-pill--neutral" text="Dokument" />
            <Label fx:id="signatureStateBadge" styleClass="autogram-pill,autogram-pill--info" text="Kontrola podpisov prebieha" />
        </FlowPane>
        <Label fx:id="activeCertificateLabel"
               styleClass="autogram-selection-chip"
               managed="false"
               visible="false"
               wrapText="true"
               maxWidth="460" />

        <HBox styleClass="autogram-signing-stepper" spacing="8" alignment="CENTER_LEFT">
            <Label fx:id="stepPreviewLabel" text="1. Náhľad dokumentu" styleClass="autogram-signing-step,autogram-signing-step--active" />
            <Label fx:id="stepSignaturesLabel" text="2. Kontrola podpisov" styleClass="autogram-signing-step" />
            <Label fx:id="stepSigningLabel" text="3. Podpísanie" styleClass="autogram-signing-step" />
        </HBox>
    </VBox>

    <VBox fx:id="inlineAlertsBox" styleClass="autogram-inline-alerts" managed="false" visible="false" />

    <StackPane styleClass="autogram-signing-preview-card" VBox.vgrow="ALWAYS">
        <!-- HTML visualization -->
        <VBox fx:id="webViewContainer" managed="false" visible="false" VBox.vgrow="ALWAYS">
            <WebView fx:id="webView" focusTraversable="false" VBox.vgrow="ALWAYS" />
        </VBox>

        <!-- PDF visualization -->
        <ScrollPane styleClass="autogram-visualizer-pdf" fx:id="pdfVisualizationContainer" managed="false" visible="false" VBox.vgrow="ALWAYS">
            <VBox fx:id="pdfVisualizationBox" VBox.vgrow="ALWAYS" />
        </ScrollPane>

        <!-- Plaintext visualization -->
        <TextArea fx:id="plainTextArea" styleClass="autogram-visualizer-plaintext" managed="false"
                  visible="false" editable="false" focusTraversable="false" VBox.vgrow="ALWAYS" />

        <!-- Image visualization -->
        <ScrollPane fx:id="imageVisualizationContainer" managed="false" visible="false" VBox.vgrow="ALWAYS">
            <VBox styleClass="autogram-visualizer-image" VBox.vgrow="ALWAYS">
                <ImageView fx:id="imageVisualization" />
            </VBox>
        </ScrollPane>

        <!-- Unsupported visualization -->
        <VBox fx:id="unsupportedVisualizationInfoBox" styleClass="autogram-unsupported-visualization"
              managed="false" visible="false" VBox.vgrow="ALWAYS">
            <VBox alignment="CENTER">
                <SVGPath styleClass="autogram-icon,autogram-icon--big,autogram-icon--warning"
                         content="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />
                <TextFlow styleClass="autogram-error-summary__error" textAlignment="CENTER">
                    <Text styleClass="autogram-error-message" text="Dokument nie&#160;je možné zobraziť. " />
                </TextFlow>
            </VBox>
            <VBox>
                <TextFlow>
                    <Text styleClass="autogram-body"
                          text="Uistite sa, že dôverujete zdroju dokumentu a&#160;máte dostatočne zabezpečený počítač, na&#160;ktorom dokument podpisujete." />
                </TextFlow>
                <TextFlow>
                    <Text styleClass="autogram-body,autogram-font-weight-bold"
                          text="Podpisovanie dokumentov, ktoré nevidíte, môže mať vážne právne následky. Zvážte, či chcete pokračovať." />
                </TextFlow>
            </VBox>
        </VBox>
    </StackPane>

    <VBox fx:id="signaturesTable" styleClass="autogram-signatures-summary-card" />

    <VBox styleClass="autogram-signing-control-surface" spacing="10">
        <HBox spacing="14" alignment="CENTER_LEFT" styleClass="autogram-options-row,autogram-signing-control-bar">
            <Label text="Formát podpisu" styleClass="autogram-label" />
            <ChoiceBox fx:id="signatureFormatChoice" styleClass="autogram-choicebox" prefWidth="220" />
            <CheckBox fx:id="timestampCheckbox" text="Pridať časovú pečiatku" styleClass="autogram-checkbox" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="changeKeyButton" styleClass="autogram-button,autogram-button--secondary"
                    text="Zmeniť certifikát" visible="false" managed="false" onAction="#onChangeKeyButtonPressed" />
            <Button fx:id="mainButton" styleClass="autogram-button" text="Podpísať dokument" onAction="#onMainButtonPressed" />
        </HBox>
        <Label styleClass="autogram-body-s"
               wrapText="true"
               text="Pred podpisom môžete upraviť certifikát, formát podpisu alebo pridať časovú pečiatku." />
    </VBox>
</VBox>
